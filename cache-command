#!/bin/bash

set -o errexit -o pipefail -o nounset -o noclobber

function usage() {
    echo -n "Usage: $(basename "${0}") "
    echo '[-b PATH] [-e SECONDS] [-h] [-p] [-r] [-v] -- COMMAND'
}

baseDir="${XDG_RUNTIME_DIR:-/tmp}/cache-command"
expirationInSeconds=
purge=false
remove=false
verbose=false

# Arg parsing from: https://stackoverflow.com/a/29754866
while getopts 'b:e:hprv' c; do
    case $c in
        b)
            baseDir="$OPTARG"
            ;;
        e)
            expirationInSeconds="$OPTARG"
            ;;
        h)
            usage
            exit
            ;;
        p)
            purge=true
            ;;
        r)
            remove=true
            ;;
        v)
            verbose=true
            ;;
        *)
            usage >&2
            exit 1
            ;;
    esac
done

shift $((OPTIND-1))

# Validate options before they are used (e.g. before -r runs `rm -rf "${baseDir}"`).
if [[ -z "${baseDir}" || "${baseDir}" = / ]]; then
    echo "Error: -b PATH must be a non-empty path other than /" >&2
    exit 1
fi
if [[ -n "${expirationInSeconds}" && ! "${expirationInSeconds}" =~ ^[0-9]+$ ]]; then
    echo "Error: -e SECONDS must be a non-negative integer" >&2
    exit 1
fi

# Remove ${baseDir} before validating the COMMAND argument, because the latter is moot in this case
if [[ "${remove}" = true ]]; then
    [[ "${verbose}" = false ]] || echo "Removing base directory: ${baseDir}"
    rm -rf $([[ "${verbose}" = false ]] || echo -n '--verbose') "${baseDir}"
    exit
fi

if [[ $# -eq 0 ]]; then
    usage >&2
    exit 1
fi

# Hash the command (NUL-delimited to preserve argument boundaries) into a cache key.
# sha256sum appends " -", which the trailing strip removes.
key="$(printf '%s\0' "$@" | sha256sum)"
key=${key%% *}
cacheDir="${baseDir}/${key}"

if [[ "${verbose}" = true ]]; then
    echo "Base directory: ${baseDir}"
    echo "Cache directory: ${cacheDir}"
    echo "Command: $*"
    echo "Expiration in seconds: ${expirationInSeconds}"
    echo "Purge: ${purge}"
    echo "Remove: ${remove}"
    echo "Verbose: ${verbose}"
fi

function removeCacheDir() {
    [[ "${verbose}" = false ]] || echo "Purging cache ${cacheDir}"
    rm -fr $([[ "${verbose}" = false ]] || echo -n '-v') "${cacheDir}"
}

if [[ "${purge}" = true ]]; then
    removeCacheDir
    exit
fi

exitCodePath="${cacheDir}/exit-code"
errPath="${cacheDir}/stderr"
outPath="${cacheDir}/stdout"

function cacheAge() {
    # GNU `stat -c` vs BSD `stat -f`; both report the modification time.
    local modifiedTime
    modifiedTime=$(stat -c %Y "${exitCodePath}" 2>/dev/null || stat -f %m "${exitCodePath}")
    echo -n $(($(date +%s)-${modifiedTime}))
}

if [[ -f "${exitCodePath}" ]]; then
    age="$(cacheAge)"
    if [[ -z ${expirationInSeconds} || ${age} -lt ${expirationInSeconds} ]]; then
        [[ "${verbose}" = false ]] || echo "Using cache (cache age in seconds: ${age})"
        cat "${outPath}"
        cat "${errPath}" 1>&2
        exit "$(cat "${exitCodePath}")"
    fi

    [[ "${verbose}" = false ]] || echo "Cache has expired (cache age in seconds: ${age})"
    removeCacheDir
fi

# Build the cache in a private temporary directory. Each invocation gets its own
# directory (via mktemp), so concurrent runs of the same COMMAND never write to each
# other's files. Files are owner-only because the output may be sensitive. The temp
# directory (and the publish lock, once held) is cleaned up on any exit or signal.
umask 077
mkdir -p "${baseDir}"
tmpDir="$(mktemp -d "${baseDir}/.tmp.XXXXXXXXXX")"
lockDir=
trap 'rm -rf "${tmpDir}" ${lockDir:+"${lockDir}"}' EXIT
trap 'exit 1' INT TERM

# Executing the COMMAND must be allowed to exit with a non-zero exit code. errexit
# stays off through publishing so a publish failure can never mask the real exit code.
set +o errexit
"$@" >"${tmpDir}/stdout" 2>"${tmpDir}/stderr"
exitCode=$?

cat "${tmpDir}/stdout"
cat "${tmpDir}/stderr" 1>&2

# Write the exit code last; its presence is what marks a cache as complete.
echo -n "${exitCode}" >"${tmpDir}/exit-code"

# Publish the cache. `mkdir` is atomic, so it serializes concurrent runs of the same
# COMMAND: exactly one wins the lock and renames its directory into place (no other
# publisher can recreate the target underneath it), and the losers simply discard
# their temp directory. A complete cache is the same regardless of which run wins.
if mkdir "${cacheDir}.lock" 2>/dev/null; then
    lockDir="${cacheDir}.lock"
    rm -rf "${cacheDir}"
    mv "${tmpDir}" "${cacheDir}"
fi
exit "${exitCode}"
